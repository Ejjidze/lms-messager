APP_NAME=EduFlow LMS API
APP_ENV=development
APP_DEBUG=true
API_HOST=127.0.0.1
API_PORT=8000
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
MEDIA_ROOT=./media
MEDIA_URL=/media
ANALYTICS_REFRESH_CRON=*/15 * * * *
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/eduflow_lms?charset=utf8mb4
